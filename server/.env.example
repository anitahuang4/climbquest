# Copy to .env and fill in.

# Your Supabase project URL (Dashboard → Project Settings → API → Project URL)
# Used to fetch the JWKS for verifying tokens signed with ES256/RS256 (the modern asymmetric flow).
SUPABASE_URL=

# Only needed if your project uses the legacy HS256 shared-secret flow.
# Find this in Supabase Dashboard → Project Settings → API → JWT Secret.
# If your tokens are signed with ES256/RS256 (default for newer projects), leave this blank.
SUPABASE_JWT_SECRET=
